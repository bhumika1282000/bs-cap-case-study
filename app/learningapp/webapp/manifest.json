{
  "_version": "1.83.0",
  "sap.app": {
    "id": "learningapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.22.0",
      "toolsId": "faf29e33-e110-4def-aee0-df31b54bc91b"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/learning/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "learningsapp-learningapp": {
          "semanticObject": "learningsapp",
          "action": "learningapp",
          "title": "{{learningsapp-learningapp.flpTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.148.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "learningapp.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "LearningsMasterDataList",
          "target": "LearningsMasterDataList"
        },
        {
          "pattern": "LearningsMasterData({key}):?query:",
          "name": "LearningsMasterDataObjectPage",
          "target": "LearningsMasterDataObjectPage"
        },
        {
          "pattern": "LearningsMasterData({key})/assignedlearnings({key2}):?query:",
          "name": "LearningsObjectPage",
          "target": "LearningsObjectPage"
        }
      ],
      "targets": {
        "LearningsMasterDataList": {
          "type": "Component",
          "id": "LearningsMasterDataList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/LearningsMasterData",
              "variantManagement": "Page",
              "navigation": {
                "LearningsMasterData": {
                  "detail": {
                    "route": "LearningsMasterDataObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          }
        },
        "LearningsMasterDataObjectPage": {
          "type": "Component",
          "id": "LearningsMasterDataObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/LearningsMasterData",
              "navigation": {
                "assignedlearnings": {
                  "detail": {
                    "route": "LearningsObjectPage"
                  }
                }
              }
            }
          }
        },
        "LearningsObjectPage": {
          "type": "Component",
          "id": "LearningsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/LearningsMasterData/assignedlearnings"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
