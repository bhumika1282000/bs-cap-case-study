{
  "_version": "1.83.0",
  "sap.app": {
    "id": "projectapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.22.0",
      "toolsId": "2514dfe5-866a-4f14-af20-fa8926fa087c"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/project/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "projectapp-projectapp": {
          "semanticObject": "projectapp",
          "action": "projectapp",
          "title": "{{projectapp-projectapp.flpTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.148.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "projectapp.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "ProjectsMasterDataList",
          "target": "ProjectsMasterDataList"
        },
        {
          "pattern": "ProjectsMasterData({key}):?query:",
          "name": "ProjectsMasterDataObjectPage",
          "target": "ProjectsMasterDataObjectPage"
        },
        {
          "pattern": "ProjectsMasterData({key})/assignedprojects({key2}):?query:",
          "name": "ProjectsObjectPage",
          "target": "ProjectsObjectPage"
        }
      ],
      "targets": {
        "ProjectsMasterDataList": {
          "type": "Component",
          "id": "ProjectsMasterDataList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/ProjectsMasterData",
              "variantManagement": "Page",
              "navigation": {
                "ProjectsMasterData": {
                  "detail": {
                    "route": "ProjectsMasterDataObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          }
        },
        "ProjectsMasterDataObjectPage": {
          "type": "Component",
          "id": "ProjectsMasterDataObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/ProjectsMasterData",
              "navigation": {
                "assignedprojects": {
                  "detail": {
                    "route": "ProjectsObjectPage"
                  }
                }
              }
            }
          }
        },
        "ProjectsObjectPage": {
          "type": "Component",
          "id": "ProjectsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/ProjectsMasterData/assignedprojects"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
