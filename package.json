{
  "name": "employee_cap_proj_bs",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/cds-typer": "^0.38.0",
    "@cap-js/cds-types": "^0.16.0",
    "@cap-js/sqlite": "^2",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@sap-ux/eslint-plugin-fiori-tools": "^9.11.7",
    "@sap/ux-ui5-tooling": "^1.24.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/sinon": "^21.0.1",
    "cds-plugin-ui5": "^0.13.0",
    "chai": "^6.2.2",
    "eslint": "^9.39.4",
    "mocha": "^11.7.6",
    "nyc": "^18.0.0",
    "sinon": "^22.0.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "tsx": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "eslint": "^9.39.4"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch --open com.employee.employeeui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-employee": "cds watch --open employee.employee/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-employeeapp": "cds watch --open employeeapp/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-learningsapp": "cds watch --open learningsapp/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-learningapp": "cds watch --open learningapp/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-projectapp": "cds watch --open projectapp/index.html?sap-ui-xx-viewCache=false --livereload false",
    "test": "rm -f db.sqlite* && mocha && rm -f db.sqlite* && cds deploy --to sqlite",
    "test:unit": "mocha 'test/unit/**/*.test.ts'",
    "test:integration": "rm -f db.sqlite* && mocha 'test/integration/**/*.test.ts' && rm -f db.sqlite* && cds deploy --to sqlite",
    "test:coverage": "nyc npm test"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      },
      "db-ext": {
        "[development]": {
          "model": "db/sqlite"
        },
        "[production]": {
          "model": "db/hana"
        }
      },
      "auth": {
        "kind": "mocked",
        "users": {
          "*": false,
          "admin": {
            "password": "admin",
            "roles": [
              "ADMIN"
            ]
          },
          "viewer": {
            "password": "viewer",
            "roles": [
              "VIEWER"
            ]
          },
          "projectadmin": {
            "password": "projectadmin",
            "roles": [
              "PROJECT_ADMIN"
            ]
          },
          "learningadmin": {
            "password": "learningadmin",
            "roles": [
              "LEARNING_ADMIN"
            ]
          }
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/employee",
    "app/employee",
    "app/employeeapp",
    "app/learningapp",
    "app/projectapp"
  ],
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  }
}
